services:
  db:
    image: postgres:15
    container_name: group_collects_db
    restart: unless-stopped
    environment:
      POSTGRES_DB: collects
      POSTGRES_USER: collects_user
      POSTGRES_PASSWORD: collects_pass
    volumes:
      - postgres_data:/var/lib/postgresql/data

  redis:
    image: redis:7
    container_name: group_collects_redis
    restart: unless-stopped

  web:
    build: .
    container_name: group_collects_web
    restart: unless-stopped
    command: >
      sh -c "
      python manage.py migrate &&
      python manage.py runserver 0.0.0.0:8000
      "
    volumes:
      - .:/app
    ports:
      - "8000:8000"
    environment:
      DJANGO_SECRET_KEY: django-insecure-dev-key
      DJANGO_DEBUG: "1"
      DJANGO_ALLOWED_HOSTS: localhost,127.0.0.1
      POSTGRES_DB: collects
      POSTGRES_USER: collects_user
      POSTGRES_PASSWORD: collects_pass
      POSTGRES_HOST: db
      POSTGRES_PORT: "5432"
      EMAIL_BACKEND: django.core.mail.backends.console.EmailBackend
      DEFAULT_FROM_EMAIL: noreply@example.com
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/0
      REDIS_CACHE_URL: redis://redis:6379/1
    depends_on:
      - db
      - redis

  worker:
    build: .
    container_name: group_collects_worker
    restart: unless-stopped
    command: celery -A config worker --loglevel=info
    volumes:
      - .:/app
    environment:
      DJANGO_SECRET_KEY: django-insecure-dev-key
      DJANGO_DEBUG: "1"
      DJANGO_ALLOWED_HOSTS: localhost,127.0.0.1
      POSTGRES_DB: collects
      POSTGRES_USER: collects_user
      POSTGRES_PASSWORD: collects_pass
      POSTGRES_HOST: db
      POSTGRES_PORT: "5432"
      EMAIL_BACKEND: django.core.mail.backends.console.EmailBackend
      DEFAULT_FROM_EMAIL: noreply@example.com
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/0
      REDIS_CACHE_URL: redis://redis:6379/1
    depends_on:
      - db
      - redis

  test:
    build: .
    container_name: group_collects_test
    command: pytest
    volumes:
      - .:/app
    environment:
      DJANGO_SECRET_KEY: django-insecure-dev-key
      DJANGO_DEBUG: "1"
      DJANGO_ALLOWED_HOSTS: localhost,127.0.0.1
      POSTGRES_DB: collects
      POSTGRES_USER: collects_user
      POSTGRES_PASSWORD: collects_pass
      POSTGRES_HOST: db
      POSTGRES_PORT: "5432"
      EMAIL_BACKEND: django.core.mail.backends.console.EmailBackend
      DEFAULT_FROM_EMAIL: noreply@example.com
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/0
      REDIS_CACHE_URL: redis://redis:6379/1
    depends_on:
      - db
      - redis

volumes:
  postgres_data:
